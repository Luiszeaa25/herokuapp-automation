{
  "name": "herokuapp-automation",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
"test": "cucumber-js --config cucumber.json",
    "test:smoke": "cucumber-js --config cucumber.json --tags \"@smoke\"",
    "test:sanity": "cucumber-js --config cucumber.json --tags \"@sanity\"",
    "test:regression": "cucumber-js --config cucumber.json --tags \"@regression\"",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open",
    "clean": "rm -rf allure-results allure-report",
    "test:smoke:report": "npm run clean && npm run test:smoke && npm run report",
    "test:sanity:report": "npm run clean && npm run test:sanity && npm run report",
    "test:regression:report": "npm run clean && npm run test:regression && npm run report",
    "test:report": "npm run clean && npm test && npm run report"
    },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
